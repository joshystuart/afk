{
  "name": "afk-desktop",
  "version": "0.1.0",
  "description": "AFK - Away From Keyboard - Desktop App",
  "main": "dist/main.js",
  "author": "joshstuartx+afk@gmail.com",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "package": "tsc && electron-builder --config electron-builder.config.js",
    "package:dir": "tsc && electron-builder --config electron-builder.config.js --dir"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.0",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.7.3"
  },
  "postinstall": "electron-rebuild"
}
